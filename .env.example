# ZNations Web — environment variables
# Copy to .env.local for local dev, and set the same keys in the Vercel
# dashboard (Project -> Settings -> Environment Variables) for production.
# Everything here is optional for the app to BOOT — with nothing set the site
# runs on seeded/demo data. Set the database + secrets to make data persist.

# --- Database (Supabase Postgres) ------------------------------------------------
# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# Use the "Transaction" pooler string (port 6543) for Vercel serverless.
# Example: postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Website auth (bootstrap accounts + session signing) -------------------------
# These seed an owner + a player login before any DB users exist. Change them.
ZN_ADMIN_USERNAME=owner
ZN_ADMIN_PASSWORD=change-this-owner-password
ZN_PLAYER_USERNAME=zayden
ZN_PLAYER_PASSWORD=change-this-player-password
# Secret used to sign session cookies (HMAC). Use a long random string.
ZN_SESSION_SECRET=change-this-session-secret

# --- Minecraft plugin -> website ingest -----------------------------------------
# The Java plugin must send `Authorization: Bearer <this>` on /api/ingest/* calls.
ZN_INGEST_SECRET=

# --- Optional durable cache (Vercel KV / Upstash Redis) --------------------------
# Without these, cache falls back to per-instance memory. Set them so plugin
# snapshots survive across Vercel serverless invocations.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Public config (safe to expose to the browser) -------------------------------
NEXT_PUBLIC_SITE_URL=https://znationssmp.com
NEXT_PUBLIC_SERVER_NAME=ZNations SMP
NEXT_PUBLIC_SERVER_ADDRESS=208.92.235.66:25565
NEXT_PUBLIC_BEDROCK_ADDRESS=208.92.235.66
NEXT_PUBLIC_BEDROCK_PORT=25565
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/CSEkkBf8cD
NEXT_PUBLIC_BLUEMAP_URL=http://208.92.235.66:2120/

# Set to "true" to force clearly-labelled demo data when nothing is wired yet.
NEXT_PUBLIC_ENABLE_DEMO_DATA=false
